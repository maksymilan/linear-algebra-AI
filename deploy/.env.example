# ===== Linear-Algebra-AI 统一环境变量（部署模板）=====
# 复制为仓库根目录 .env 并填入真实值：cp deploy/.env.example .env
# web_service 与 ai_service 启动时都会加载仓库根目录的 .env。

# --- 数据库（DB_SOURCE 给 web_service；下面分项给 ai_service；两者必须指向同一个库）---
# 注意：用 URL 形式（无空格），方便所有工具解析。host 用 127.0.0.1（pgvector 容器映射到宿主 5432）。
DB_SOURCE=postgres://postgres:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/LA-DB
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=LA-DB
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# --- 鉴权 / 注册白名单 ---
# JWT_SECRET 上线【必须】改成长随机串，否则任何人可伪造登录 token：openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RANDOM_64_HEX
# ⚠️ 下列邮箱可用同一邮箱无限注册、且免验证码——仅供内测。正式上线如不需要，请把这三项【清空】。
REGISTER_EMAIL_CHECK_BYPASS=3230105779@zju.edu.cn
REGISTER_TEST_CODE_EMAILS=3230105779@zju.edu.cn
REGISTER_TEST_CODE=123456
# CORS 允许的源（逗号分隔）。nginx 同源部署可留空(=放开)；要收紧填前端域名，如 https://la.example.com
CORS_ALLOWED_ORIGINS=

# --- 邮件验证码（MAIL_PROVIDER=aliyun 时走 SMTP；其他值则只打印到日志）---
MAIL_PROVIDER=console
ALIYUN_DM_SMTP_HOST=
ALIYUN_DM_SMTP_PORT=465
ALIYUN_DM_SMTP_USER=
ALIYUN_DM_SMTP_PASSWORD=
ALIYUN_DM_FROM_NAME=线性代数助教

# --- 服务间地址 / ai_service 监听 ---
AI_SERVICE_BASE_URL=http://127.0.0.1:8000
# ai_service 监听地址：默认仅回环，防止无鉴权服务被公网直连。【不要】改成 0.0.0.0
AI_BIND_HOST=127.0.0.1

# --- AI 提供商（ai_service 调大模型）---
AI_API_KEY=CHANGE_ME_AIHUBMIX_KEY
AI_BASE_URL=https://aihubmix.com/v1
AI_VL_MODEL_NAME=deepseek-ocr
# 说明：具体用哪些模型在 ai_service/model_config.json 配置（OCR/问答/批改/向量等角色）。
#   AI_CHAT_MODEL / AI_GRADING_MODEL / AI_EMBEDDING_MODEL 等是可选的 env 覆盖，一般留空走 model_config.json。
#   QWEN_API_KEY / QWEN_URL 是 AI_API_KEY / AI_BASE_URL 的旧别名，二选一即可，无需重复填。
